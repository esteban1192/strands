<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="014" author="system" context="all">
        <comment>Add command, args, and env columns to mcps table for stdio transport support</comment>

        <addColumn schemaName="strands" tableName="mcps">
            <column name="command" type="VARCHAR(1024)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn schemaName="strands" tableName="mcps">
            <column name="args" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn schemaName="strands" tableName="mcps">
            <column name="env" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn schemaName="strands" tableName="mcps" columnName="command"/>
            <dropColumn schemaName="strands" tableName="mcps" columnName="args"/>
            <dropColumn schemaName="strands" tableName="mcps" columnName="env"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
