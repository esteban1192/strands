<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-create-tools-table" author="system" context="all">
        <comment>Create Tools table for tools that can be used by agents</comment>
        
        <createTable tableName="tools" schemaName="strands">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="mcp_id" type="UUID">
                <constraints nullable="true"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="tool_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="configuration" type="JSONB"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="VARCHAR(50)" defaultValue="1.0.0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint 
            tableName="tools" 
            columnNames="name, version" 
            constraintName="uk_tools_name_version"
            schemaName="strands"/>

        <rollback>
            DROP TABLE IF EXISTS strands.tools;
        </rollback>
    </changeSet>

    <changeSet id="004-add-tools-foreign-key" author="system" context="all">
        <comment>Add foreign key constraint for tools to MCPs</comment>
        
        <addForeignKeyConstraint 
            baseTableName="tools" 
            baseColumnNames="mcp_id"
            referencedTableName="mcps"
            referencedColumnNames="id"
            constraintName="fk_tools_mcp_id"
            baseTableSchemaName="strands"
            referencedTableSchemaName="strands"
            onDelete="SET NULL"
            onUpdate="CASCADE"/>

        <rollback>
            ALTER TABLE strands.tools DROP CONSTRAINT IF EXISTS fk_tools_mcp_id;
        </rollback>
    </changeSet>

</databaseChangeLog>