<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="019" author="system" context="all">
        <comment>Create chat_tool_calls table for structured tool call data</comment>

        <createTable schemaName="strands" tableName="chat_tool_calls">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="message_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_chat_tool_calls_message"
                             references="strands.chat_messages(id)"
                             deleteCascade="true"
                             unique="true"
                             uniqueConstraintName="uq_chat_tool_calls_message"/>
            </column>
            <column name="tool_use_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="tool_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="input" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex schemaName="strands" tableName="chat_tool_calls" indexName="idx_chat_tool_calls_tool_name">
            <column name="tool_name"/>
        </createIndex>

        <createIndex schemaName="strands" tableName="chat_tool_calls" indexName="idx_chat_tool_calls_tool_use_id">
            <column name="tool_use_id"/>
        </createIndex>

        <rollback>
            <dropTable schemaName="strands" tableName="chat_tool_calls"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
