<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="011" author="system" context="all">
        <comment>Make model column mandatory in agents table</comment>
        
        <!-- First, set a default value for any existing NULL model values -->
        <sql>
            UPDATE strands.agents SET model = 'unknown' WHERE model IS NULL;
        </sql>
        
        <!-- Then make the column NOT NULL -->
        <addNotNullConstraint 
            schemaName="strands" 
            tableName="agents" 
            columnName="model" 
            columnDataType="VARCHAR(255)"/>

        <rollback>
            <dropNotNullConstraint schemaName="strands" tableName="agents" columnName="model" columnDataType="VARCHAR(255)"/>
        </rollback>
    </changeSet>
</databaseChangeLog>