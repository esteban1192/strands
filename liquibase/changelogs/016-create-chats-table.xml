<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="016" author="system" context="all">
        <comment>Create chats table for storing agent conversations</comment>

        <createTable schemaName="strands" tableName="chats">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="agent_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_chats_agent"
                             references="strands.agents(id)"
                             deleteCascade="true"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex schemaName="strands" tableName="chats" indexName="idx_chats_agent_id">
            <column name="agent_id"/>
        </createIndex>

        <createIndex schemaName="strands" tableName="chats" indexName="idx_chats_updated_at">
            <column name="updated_at" descending="true"/>
        </createIndex>

        <rollback>
            <dropTable schemaName="strands" tableName="chats"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
