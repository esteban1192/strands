<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="022" author="system" context="all">
        <comment>Add is_approved boolean to chat_messages table (default FALSE)</comment>

        <addColumn schemaName="strands" tableName="chat_messages">
            <column name="is_approved" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn schemaName="strands" tableName="chat_messages" columnName="is_approved"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
