<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="015" author="system" context="all">
        <comment>Add system_prompt column to agents table for per-agent instructions</comment>

        <addColumn schemaName="strands" tableName="agents">
            <column name="system_prompt" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn schemaName="strands" tableName="agents" columnName="system_prompt"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
