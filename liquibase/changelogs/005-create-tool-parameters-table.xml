<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005-create-tool-parameters-table" author="system" context="all">
        <comment>Create Tool Parameters table for tool parameter configurations</comment>
        
        <createTable tableName="tool_parameters" schemaName="strands">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tool_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="parameter_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="parameter_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="parameter_value" type="TEXT"/>
            <column name="default_value" type="TEXT"/>
            <column name="is_required" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="validation_rules" type="JSONB"/>
            <column name="description" type="TEXT"/>
            <column name="sort_order" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint 
            tableName="tool_parameters" 
            columnNames="tool_id, parameter_name" 
            constraintName="uk_tool_parameters_tool_name"
            schemaName="strands"/>

        <rollback>
            DROP TABLE IF EXISTS strands.tool_parameters;
        </rollback>
    </changeSet>

    <changeSet id="005-add-tool-parameters-foreign-key" author="system" context="all">
        <comment>Add foreign key constraint for tool parameters to tools</comment>
        
        <addForeignKeyConstraint 
            baseTableName="tool_parameters" 
            baseColumnNames="tool_id"
            referencedTableName="tools"
            referencedColumnNames="id"
            constraintName="fk_tool_parameters_tool_id"
            baseTableSchemaName="strands"
            referencedTableSchemaName="strands"
            onDelete="CASCADE"
            onUpdate="CASCADE"/>

        <rollback>
            ALTER TABLE strands.tool_parameters DROP CONSTRAINT IF EXISTS fk_tool_parameters_tool_id;
        </rollback>
    </changeSet>

    <changeSet id="005-add-tool-parameters-type-check" author="system" context="all">
        <comment>Add check constraint for tool parameters type field</comment>
        
        <sql>
            ALTER TABLE strands.tool_parameters ADD CONSTRAINT ck_tool_parameters_type 
            CHECK (parameter_type IN ('string', 'integer', 'float', 'boolean', 'json', 'array', 'object'));
        </sql>

        <rollback>
            ALTER TABLE strands.tool_parameters DROP CONSTRAINT IF EXISTS ck_tool_parameters_type;
        </rollback>
    </changeSet>

</databaseChangeLog>